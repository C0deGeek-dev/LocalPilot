          "default": null,
          "description": "Program to execute directly when `args` is provided; otherwise treated as a shell command line.",
          "type": [
            "string",
            "null"
          ]
        },
        "timeout_secs": {
          "default": null,
          "description": "Timeout in seconds. Defaults to 60.",
          "format": "uint64",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "title": "RunShellInput",
      "type": "object"
    }
