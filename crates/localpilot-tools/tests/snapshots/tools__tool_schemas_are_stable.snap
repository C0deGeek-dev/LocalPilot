        },
        "path": {
          "description": "Path to edit within the workspace.",
          "type": "string"
        }
      },
      "required": [
        "new_text",
        "old_text",
        "path"
      ],
      "title": "EditFileInput",
      "type": "object"
    }
  ],
  [
    "multi_edit",
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
