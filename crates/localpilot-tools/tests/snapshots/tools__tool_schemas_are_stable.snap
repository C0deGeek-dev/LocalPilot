  [
    "search_text",
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "properties": {
        "is_regex": {
          "default": false,
          "description": "Treat `query` as a regular expression. Defaults to false (literal).",
          "type": "boolean"
        },
        "max_matches": {
          "default": null,
          "description": "Maximum number of matches to return.",
          "format": "uint",
          "minimum": 0.0,
