              "type": "string"
            },
            "old_text": {
              "description": "Exact text to replace.",
              "type": "string"
            }
          },
          "required": [
            "new_text",
            "old_text"
          ],
          "type": "object"
        }
      },
      "properties": {
        "edits": {
          "description": "Ordered exact-text replacements. Each `old_text` must match exactly once at the point that edit is applied.",
          "items": {
            "$ref": "#/definitions/TextEditInput"
          },
          "type": "array"
        },
        "path": {
          "description": "Path to edit within the workspace.",
          "type": "string"
        }
      },
      "required": [
