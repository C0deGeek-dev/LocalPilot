---
source: crates/localpilot-tools/tests/tools.rs
expression: "serde_json::to_string_pretty(&schemas).unwrap()"
---
[
  [
    "read_file",
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "properties": {
        "end_line": {
          "default": null,
          "description": "Last line to include (1-based, inclusive).",
          "format": "uint",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "path": {
          "description": "Workspace-relative or absolute path to read.",
          "type": "string"
        },
        "start_line": {
          "default": null,
          "description": "First line to include (1-based, inclusive).",
          "format": "uint",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "path"
      ],
      "title": "ReadFileInput",
      "type": "object"
    }
  ],
  [
    "write_file",
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "properties": {
        "content": {
          "description": "File contents.",
          "type": "string"
        },
        "overwrite": {
          "default": null,
          "description": "Allow replacing an existing file. Defaults to true (overwrite is gated by the permission engine).",
