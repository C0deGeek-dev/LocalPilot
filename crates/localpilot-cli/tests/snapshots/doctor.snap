LocalPilot <version>
  binary: <binary>

platform:
  os:   <os>
  arch: <arch>

config search paths:
  user: <config-home>/localpilot/config.toml (missing)
  project: <workspace>/.localpilot.toml (present)

providers:
  local (local): credential LOCALPILOT_LOCAL_API_KEY [not set]; model (none); context window unknown
  openai (openai): credential OPENAI_API_KEY [not set]; model (none); context window unknown
  anthropic (anthropic): credential ANTHROPIC_API_KEY [not set]; model (none); context window unknown

tools:
  git (git): available
  ripgrep (rg): available

memory store: <memory-root>
capabilities: doctor-json, models-json, learning-workspace-flag, print-turn-timeout

workspace trust: unknown (evaluated when a session starts)
